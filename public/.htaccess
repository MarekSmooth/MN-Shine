# MN Shine Detailing — statický export Next.js pro Apache (Wedos hosting)

DirectoryIndex index.html

# Next.js export vytváří pro každou stránku i stejnojmennou složku s interními
# prefetch daty (__next.*.txt). Bez tohoto se Apache pokouší k ní připojit
# lomku (mod_dir) a níže uvedené pravidlo ji zase odpojuje -> nekonečná smyčka.
<IfModule mod_dir.c>
  DirectorySlash Off
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On

  # /cesta/ -> /cesta (pokud existuje /cesta.html), aby se predeslo prazdnym slozkam
  RewriteCond %{REQUEST_URI} ^/(.+)/$
  RewriteCond %{DOCUMENT_ROOT}/$1.html -f
  RewriteRule ^(.+)/$ /$1 [R=301,L]

  # Existujici soubory (obrazky, _next/static, .txt apod.) servuj primo
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^ - [L]

  # /cesta -> /cesta.html
  RewriteCond %{REQUEST_FILENAME}\.html -f
  RewriteRule ^(.*)$ $1.html [L]
</IfModule>

ErrorDocument 404 /404.html

<IfModule mod_mime.c>
  AddType image/webp .webp
  AddType text/css .css
  AddType application/javascript .js
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
</IfModule>
